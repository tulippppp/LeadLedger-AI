# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Your wallet private key (without 0x prefix is fine too)
PRIVATE_KEY=your_private_key_here

# Optional: contract address after deployment
# LEAD_LEDGER_ADDRESS=0xYourDeployedContract

# Shardeum RPC URLs (defaults are already set in hardhat.config.js)
# Uncomment to override:
# SHARDEUM_TESTNET_RPC=https://api-mezame.shardeum.org
# SHARDEUM_MAINNET_RPC=https://api.shardeum.org
